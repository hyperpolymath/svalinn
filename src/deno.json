{
  "name": "@svalinn/gateway",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run --watch ../tools/mvp/svalinn_gateway.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run ../tools/mvp/svalinn_gateway.ts",
    "build": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-run -o dist/svalinn ../tools/mvp/svalinn_gateway.ts",
    "test": "deno test --allow-net --allow-read --allow-env",
    "check": "deno check ../tools/mvp/svalinn_gateway.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/json": "jsr:@std/json@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "ajv": "npm:ajv@^8",
    "ajv-formats": "npm:ajv-formats@^3",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
